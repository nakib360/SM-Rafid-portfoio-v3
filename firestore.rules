rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidSubmission(data) {
      return data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.email is string && data.email.size() >= 5 && data.email.size() <= 150 &&
             data.message is string && data.message.size() >= 10 && data.message.size() <= 1000 &&
             data.createdAt == request.time;
    }

    match /contactSubmissions/{submissionId} {
      allow create: if isValidId(submissionId) && isValidSubmission(incoming());
      allow read, update, delete: if false; // Only allow creation from public
    }
  }
}
